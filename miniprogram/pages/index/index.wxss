.page {
  min-height: 100vh;
  padding: 20rpx 18rpx 144rpx;
  background: #fff7ed;
  box-sizing: border-box;
}

.summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border: 3rpx solid #f1c796;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 0 rgba(194, 65, 12, 0.10);
}

.brand {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 14rpx;
}

.brand-icon {
  width: 84rpx;
  height: 84rpx;
  flex: none;
  border: 3rpx solid #f1c796;
  border-radius: 8rpx;
  background: #fff7ed;
  box-shadow: 0 4rpx 0 rgba(194, 65, 12, 0.10);
}

.brand-copy {
  min-width: 0;
  flex: 1;
}

.eyebrow {
  display: block;
  color: #8a6a48;
  font-size: 21rpx;
  margin-bottom: 4rpx;
}

.title {
  display: block;
  max-width: 330rpx;
  color: #3b260f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-pill {
  min-width: 148rpx;
  padding: 12rpx 16rpx;
  border: 3rpx solid #9a3412;
  border-radius: 8rpx;
  color: #ffffff;
  background: #f97316;
  text-align: right;
  box-shadow: 0 4rpx 0 #9a3412;
  box-sizing: border-box;
  transition: transform 120ms ease, opacity 120ms ease, box-shadow 120ms ease;
}

.cart-count,
.cart-label {
  display: block;
  line-height: 1.3;
}

.cart-count {
  font-size: 21rpx;
  color: #ffedd5;
}

.cart-label {
  font-size: 28rpx;
  font-weight: 700;
}

.tap-target {
  position: relative;
  z-index: 2;
  pointer-events: auto;
}

.admin-entry {
  margin: 0 0 12rpx;
  padding: 14rpx 18rpx;
  border: 3rpx solid #f1c796;
  border-radius: 8rpx;
  background: #ffffff;
  color: #c2410c;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 4rpx 0 rgba(194, 65, 12, 0.10);
  transition: transform 120ms ease, opacity 120ms ease, box-shadow 120ms ease;
}

.shop-layout {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.category-nav {
  width: 148rpx;
  flex: none;
  padding: 10rpx 8rpx;
  background: #ffffff;
  border: 3rpx solid #f1c796;
  border-radius: 8rpx;
  box-shadow: 0 6rpx 0 rgba(194, 65, 12, 0.10);
  box-sizing: border-box;
}

.tab {
  position: relative;
  z-index: 2;
  min-height: 68rpx;
  padding: 8rpx;
  margin-bottom: 8rpx;
  border: 3rpx solid transparent;
  border-radius: 8rpx;
  color: #7c5630;
  font-size: 25rpx;
  box-sizing: border-box;
  transition: transform 120ms ease, opacity 120ms ease, background 120ms ease, border-color 120ms ease;
}

.tab.active {
  color: #c2410c;
  background: #ffedd5;
  font-weight: 700;
  border-color: #fb923c;
  box-shadow: inset 0 -3rpx 0 rgba(194, 65, 12, 0.12);
}

.tab-name,
.tab-count {
  display: block;
}

.tab-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tab-count {
  display: inline-block;
  min-width: 34rpx;
  margin-top: 6rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  background: #fff7ed;
  color: #8a6a48;
  font-size: 19rpx;
  text-align: center;
}

.tab.active .tab-count {
  color: #ffffff;
  background: #f97316;
}

.content {
  min-width: 0;
  flex: 1;
  padding: 14rpx;
  background: #ffffff;
  border: 3rpx solid #f1c796;
  border-radius: 8rpx;
  box-shadow: 0 6rpx 0 rgba(194, 65, 12, 0.10);
  box-sizing: border-box;
}

.section-head,
.product-row,
.product-actions,
.drawer-header,
.drawer-total,
.cart-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-head {
  margin-bottom: 14rpx;
}

.section-title {
  color: #3b260f;
  font-size: 31rpx;
  font-weight: 700;
}

.result-count {
  flex: none;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #fff7ed;
  color: #7c5630;
  font-size: 21rpx;
  border: 2rpx solid #fed7aa;
}

.product {
  padding: 14rpx;
  margin-bottom: 14rpx;
  background: #fffaf5;
  border: 3rpx solid #f3d6b6;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 0 rgba(194, 65, 12, 0.08);
}

.product-image {
  width: 100%;
  height: 196rpx;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
  background: #fff7ed;
  border: 3rpx solid #f3d6b6;
}

.product-body {
  min-width: 0;
}

.name-block {
  min-width: 0;
  flex: 1;
}

.category {
  display: inline-block;
  margin-bottom: 6rpx;
  padding: 3rpx 9rpx;
  border-radius: 8rpx;
  background: #ffedd5;
  color: #c2410c;
  font-size: 19rpx;
  font-weight: 700;
  border: 2rpx solid #fdba74;
}

.product-name {
  display: block;
  min-width: 0;
  color: #3b260f;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price {
  flex: none;
  color: #c2410c;
  font-size: 30rpx;
  font-weight: 700;
}

.description {
  display: block;
  color: #8a6a48;
  font-size: 23rpx;
  line-height: 1.45;
  margin: 10rpx 0 14rpx;
  word-break: break-all;
}

.source {
  color: #8a6a48;
  font-size: 21rpx;
}

.add {
  display: block;
  position: relative;
  z-index: 3;
  height: 54rpx;
  line-height: 54rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 3rpx solid #9a3412;
  border-radius: 8rpx;
  color: #ffffff;
  background: #f97316;
  font-size: 23rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 4rpx 0 #9a3412;
  transition: transform 120ms ease, opacity 120ms ease, box-shadow 120ms ease;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.38);
  z-index: 10;
}

.drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 76vh;
  padding: 26rpx 24rpx 36rpx;
  background: #ffffff;
  border-radius: 8rpx 8rpx 0 0;
  border-top: 3rpx solid #f1c796;
  overflow-y: auto;
  z-index: 11;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
}

.close {
  color: #c2410c;
  font-size: 25rpx;
  transition: transform 120ms ease, opacity 120ms ease;
}

.empty {
  padding: 40rpx 0;
  color: #8a6a48;
  text-align: center;
}

.cart-item {
  padding: 18rpx 0;
  border-bottom: 2rpx dashed #f3d6b6;
  align-items: center;
}

.cart-name,
.cart-meta {
  display: block;
}

.cart-info {
  min-width: 0;
  flex: 1;
}

.cart-name {
  font-size: 27rpx;
  color: #3b260f;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a6a48;
}

.cart-side {
  min-width: 108rpx;
  text-align: right;
  flex: none;
}

.cart-line-price,
.cart-line-qty {
  display: block;
}

.cart-line-price {
  color: #c2410c;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.25;
}

.cart-line-qty {
  margin-top: 2rpx;
  color: #8a6a48;
  font-size: 21rpx;
}

.quantity {
  display: flex;
  gap: 8rpx;
  flex: none;
}

.step {
  display: block;
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  border: 3rpx solid #fdba74;
  background: #ffedd5;
  color: #3b260f;
  font-size: 26rpx;
  text-align: center;
  box-shadow: 0 3rpx 0 rgba(194, 65, 12, 0.14);
  transition: transform 120ms ease, opacity 120ms ease, box-shadow 120ms ease;
}

.drawer-total {
  padding-top: 22rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.submit-config {
  display: block;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  margin: 22rpx 0 0;
  border: 3rpx solid #9a3412;
  border-radius: 8rpx;
  background: #f97316;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 4rpx 0 #9a3412;
  transition: transform 120ms ease, opacity 120ms ease, box-shadow 120ms ease;
}
