<view class="page">
  <view class="summary">
    <view>
      <text class="eyebrow">CSV 可配置硬件列表</text>
      <text class="title">装机装备清单</text>
    </view>
    <view class="cart-pill" bindtap="openCart">
      <text class="cart-count">{{cartCount}} 件</text>
      <text class="cart-label">￥{{cartTotal}}</text>
    </view>
  </view>

  <view class="shop-layout">
    <scroll-view class="category-nav" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="name"
        class="tab {{activeCategory === item.name ? 'active' : ''}}"
        bindtap="selectCategory"
        data-name="{{item.name}}"
      >
        <text class="tab-name">{{item.name}}</text>
        <text class="tab-count">{{item.count}}</text>
      </view>
    </scroll-view>

    <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="section-head">
        <view>
          <text class="eyebrow">当前分类</text>
          <text class="section-title">{{activeCategory === '全部' ? '全部装备' : activeCategory}}</text>
        </view>
        <text class="result-count">{{visibleItems.length}} 项</text>
      </view>

      <view wx:for="{{visibleItems}}" wx:key="id" class="product">
        <image class="product-image" src="{{item['硬件图片']}}" mode="aspectFill" />
        <view class="product-body">
          <view class="product-row">
            <view class="name-block">
              <text class="category">{{item['硬件分类']}}</text>
              <text class="product-name">{{item['硬件名称']}}</text>
            </view>
            <text class="price">￥{{item.price}}</text>
          </view>
          <text class="description">{{item['硬件描述']}}</text>
          <view class="product-actions">
            <text class="source">装备档案</text>
            <button class="add" bindtap="addToCart" data-id="{{item.id}}">加入</button>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{cartVisible}}" class="drawer-mask" bindtap="closeCart">
    <view class="drawer" catchtap="noop">
      <view class="drawer-header">
        <text class="drawer-title">购物车</text>
        <text class="close" bindtap="closeCart">关闭</text>
      </view>
      <view wx:if="{{cartItems.length === 0}}" class="empty">还没有选择硬件</view>
      <view wx:for="{{cartItems}}" wx:key="id" class="cart-item">
        <view>
          <text class="cart-name">{{item['硬件名称']}}</text>
          <text class="cart-meta">￥{{item.price}} x {{item.quantity}}</text>
        </view>
        <view class="quantity">
          <button class="step" bindtap="decreaseCart" data-id="{{item.id}}">-</button>
          <button class="step" bindtap="increaseCart" data-id="{{item.id}}">+</button>
        </view>
      </view>
      <view class="drawer-total">
        <text>合计</text>
        <text>￥{{cartTotal}}</text>
      </view>
      <button class="submit-config" bindtap="submitConfig">提交配置</button>
    </view>
  </view>
</view>
