<view class="page">
  <view class="summary">
    <view class="brand">
      <image class="brand-icon" src="/assets/huiwen-computer-icon.png" mode="aspectFit" />
      <view class="brand-copy">
        <text class="eyebrow">会稳电脑</text>
        <text class="title">装机配置清单</text>
      </view>
    </view>
    <view class="cart-pill tap-target" bind:tap="openCart">
      <text class="cart-count">{{cartCount}} 件</text>
      <text class="cart-label">￥{{cartTotal}}</text>
    </view>
  </view>
  <view class="tap-status">{{tapStatus}}</view>

  <view class="shop-layout">
    <view class="category-nav">
      <view
        wx:for="{{categories}}"
        wx:key="name"
        class="tab {{activeCategory === item.name ? 'active' : ''}}"
        bind:tap="selectCategory"
        data-name="{{item.name}}"
      >
        <text class="tab-name">{{item.name}}</text>
        <text class="tab-count">{{item.count}}</text>
      </view>
    </view>

    <view class="content">
      <view class="section-head">
        <view>
          <text class="eyebrow">当前分类</text>
          <text class="section-title">{{activeCategory === '全部' ? '全部商品' : activeCategory}}</text>
        </view>
        <text class="result-count">{{visibleItems.length}} 项</text>
      </view>

      <view wx:for="{{visibleItems}}" wx:key="id" class="product">
        <image class="product-image" src="{{item['硬件图片']}}" mode="aspectFill" />
        <view class="product-body">
          <view class="product-row">
            <view class="name-block">
              <text class="category">{{item['硬件分类']}}</text>
              <text class="product-name">{{item['硬件名称']}}</text>
            </view>
            <text class="price">￥{{item.price}}</text>
          </view>
          <text class="description">{{item['硬件描述']}}</text>
          <view class="product-actions">
            <text class="source">商品信息</text>
            <view class="add tap-target" bind:tap="addToCart" data-id="{{item.id}}">加入</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{cartVisible}}" class="drawer-mask" bind:tap="closeCart">
    <view class="drawer" catch:tap="noop">
      <view class="drawer-header">
        <text class="drawer-title">购物车</text>
        <text class="close tap-target" bind:tap="closeCart">关闭</text>
      </view>
      <view wx:if="{{cartItems.length === 0}}" class="empty">还没有选择硬件</view>
      <view wx:for="{{cartItems}}" wx:key="id" class="cart-item">
        <view class="cart-info">
          <text class="cart-name">{{item['硬件名称']}}</text>
          <text class="cart-meta">{{item['硬件分类']}}</text>
        </view>
        <view class="cart-side">
          <text class="cart-line-price">￥{{item.price}}</text>
          <text class="cart-line-qty">x {{item.quantity}}</text>
        </view>
        <view class="quantity">
          <view class="step tap-target" bind:tap="decreaseCart" data-id="{{item.id}}">-</view>
          <view class="step tap-target" bind:tap="increaseCart" data-id="{{item.id}}">+</view>
        </view>
      </view>
      <view class="drawer-total">
        <text>合计</text>
        <text>￥{{cartTotal}}</text>
      </view>
      <view class="submit-config tap-target" bind:tap="submitConfig">提交配置</view>
    </view>
  </view>
</view>
